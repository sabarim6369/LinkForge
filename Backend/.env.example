# LinkForge Backend - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================
# SERVER CONFIGURATION
# ============================================================
NODE_ENV=development
PORT=5000
CORS_ORIGIN=*

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/linkforge

# ============================================================
# AI/LLM CONFIGURATION (Groq API)
# ============================================================
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=mixtral-8x7b-32768

# ============================================================
# EMAIL CONFIGURATION
# ============================================================
# Gmail: https://support.google.com/accounts/answer/185833
# Other providers: configure accordingly
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECIPIENT=recipient@example.com

# ============================================================
# SECURITY
# ============================================================
TOKEN_SECRET=your_jwt_secret_key_change_in_production
TOKEN_EXPIRY=24h
ADMIN_API_KEY=your_admin_api_key_here

# ============================================================
# NEWS SOURCES (Optional APIs)
# ============================================================
NEWS_API_KEY=your_newsapi_key_here
PRODUCT_HUNT_API_KEY=your_producthunt_api_key

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info

# ============================================================
# CRON SCHEDULE
# ============================================================
# Format: minute hour day month weekday (cron format)
# Default: 0 8 * * * (8 AM every day)
# Examples:
#   0 9 * * * = 9 AM daily
#   0 */6 * * * = Every 6 hours
#   30 8 * * 1-5 = 8:30 AM Monday-Friday
CRON_SCHEDULE=* * * * * *

# ============================================================
# APPLICATION URL
# ============================================================
# Used in email links for posting
APP_URL=http://localhost:5000
