{
  "name": "linkforge-backend",
  "version": "1.0.0",
  "description": "AI-powered personal branding assistant - fetches news, generates LinkedIn posts, sends daily digests",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "cross-env NODE_ENV=development nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "seed": "node scripts/seed.js",
    "migrate": "node scripts/migrate.js"
  },
  "keywords": [
    "ai",
    "linked-in",
    "news-aggregation",
    "groq",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "json-web-token": "^1.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "node-cron": "^3.0.2",
    "node-fetch": "^2.6.11",
    "nodemailer": "^6.9.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "dotenv": "^16.0.3",
    "eslint": "^8.36.0",
    "jest": "^29.5.0",
    "nodemon": "^2.0.20"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
